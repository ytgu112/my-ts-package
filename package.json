{
  "name": "@ytgu/my-ts-package",
  "version": "1.0.6",
  "description": "A simple TypeScript package",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "echo 'Running integration tests...' && exit 0",
    "dev": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "@types/node": "^20.0.0"
  }
}